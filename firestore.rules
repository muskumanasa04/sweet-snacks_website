rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Suites (Sweets & Snacks listings)
    match /suites/{suiteId} {
      allow read: if true; // anyone can browse sweet products
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && existing().ownerEmail == request.auth.token.email;
    }

    // 2. Reviews
    match /reviews/{reviewId} {
      allow read: if true; // anyone can check product ratings
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // 3. Bookings (Orders)
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        resource.data.guestEmail == request.auth.token.email || 
        resource.data.chefEmail == request.auth.token.email ||
        request.auth.token.email == 'admin.chief@sweetstay.com'
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (
        existing().guestEmail == request.auth.token.email || 
        request.auth.token.email == 'admin.chief@sweetstay.com'
      );
    }

    // 4. Chef Contact Requests
    match /contactRequests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.buyerEmail == request.auth.token.email || 
        resource.data.chefEmail == request.auth.token.email
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        existing().chefEmail == request.auth.token.email ||
        existing().buyerEmail == request.auth.token.email
      );
      allow delete: if isSignedIn() && (
        existing().chefEmail == request.auth.token.email ||
        existing().buyerEmail == request.auth.token.email
      );
    }

    // 5. Chef Onboardings
    match /chefOnboardings/{onboardingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 6. Contact Schedules (Consultations/Bulk Orders)
    match /contactSchedules/{scheduleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 7. System Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (
        resource.data.recipientEmail == request.auth.token.email || 
        resource.data.recipientEmail == 'all-admins' || 
        resource.data.recipientEmail == 'all-owners'
      );
      allow write: if isSignedIn();
    }

    // 8. Users
    match /users/{userId} {
      allow read: if true; // profiles can be fetched for displaying names
      allow write: if isSignedIn();
    }
  }
}
